# ── RentEscrow Backend Environment ──────────────────────────
# Copy this file to .env and fill in your values

# Blockchain RPC URL
# Local Hardhat:  http://127.0.0.1:8545
# Sepolia:        https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_URL=http://127.0.0.1:8545

# EscrowFactory deployed address (set after running deploy script)
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Chain ID (31337 = Hardhat local, 11155111 = Sepolia)
CHAIN_ID=31337

# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
